{
  "name": "sparstogram",
  "version": "0.9.0",
  "description": "Sparse, adaptive, scalable histogram in TypeScript",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "clean": "rm -rf dist/",
    "doc": "npx typedoc -out docs src",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "test": "node --loader=ts-node/esm node_modules/mocha/bin/mocha.js src/**/*.test.ts --colors",
    "prepublish": "npm run build && npm run doc"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Digithought/Sparstogram.git"
  },
  "homepage": "https://github.com/Digithought/Sparstogram",
  "bugs": {
    "url": "https://github.com/Digithought/Sparstogram/issues"
  },
  "keywords": [
    "histogram",
    "sparse",
    "t-digest",
    "q-digest",
    "statistics",
    "financial",
    "median"
  ],
  "author": "Nathan T. Allan",
  "license": "MIT",
  "devDependencies": {
    "@types/chai": "^5.2.2",
    "@types/mocha": "^10.0.10",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "chai": "^5.2.0",
    "eslint": "^9.27.0",
    "mocha": "^11.4.0",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.4",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "digitree": "^1.4.0"
  }
}
