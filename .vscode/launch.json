{
	"version": "0.2.0",
	"configurations": [
			{
					"type": "pwa-node",
					"request": "launch",
					"name": "Mocha - Current Test File",
					"runtimeExecutable": "node",
					"runtimeArgs": [
							"--import",
							"tsx"
					],
					"program": "${workspaceFolder}/node_modules/mocha/bin/mocha.js",
					"args": [
							"${file}",
							"--colors"
					],
					"console": "integratedTerminal",
					"internalConsoleOptions": "neverOpen",
					"cwd": "${workspaceFolder}"
			},
			{
					"type": "pwa-node",
					"request": "launch",
					"name": "Mocha - All Tests",
					"runtimeExecutable": "node",
					"runtimeArgs": [
							"--import",
							"tsx"
					],
					"program": "${workspaceFolder}/node_modules/mocha/bin/mocha.js",
					"args": [
							"src/**/*.test.ts",
							"--colors"
					],
					"console": "integratedTerminal",
					"internalConsoleOptions": "neverOpen",
					"cwd": "${workspaceFolder}"
			}
	]
}
